page {
  background: #0f172a;
  color: #f1f5f9;
}
.banner {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.banner-show {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.search {
  text-align: center;
  position: fixed;
  width: 100%;
  z-index: 10;
}
.search-input {
  background: rgba(99,102,241,0.15);
  height: 80rpx;
  border-radius: 26rpx;
  width: 72%;
  margin: 0 auto;
  color: #f1f5f9;
  padding: 0 30rpx;
  font-weight: bold;
  border: 1rpx solid rgba(99,102,241,0.3);
}

.place {
  width: 100%;
  height: 280rpx;
}
.empty-search {
  font-size: 28rpx;
  color: #64748b;
  text-align: center;
  margin-top: 70px;
}

.result-list {
  padding: 0 32rpx;
}
.result-item {
  background: rgba(30,41,59,0.5);
  border: 1rpx solid rgba(148,163,184,0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.ri-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.ri-date {
  font-size: 26rpx;
  color: #94a3b8;
}
.ri-hours {
  font-size: 28rpx;
  font-weight: 700;
  color: #f1f5f9;
}
.ri-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.ri-income {
  font-size: 34rpx;
  font-weight: 800;
  color: #10b981;
}
.ri-desc {
  font-size: 24rpx;
  color: #64748b;
  max-width: 60%;
  text-align: right;
}
