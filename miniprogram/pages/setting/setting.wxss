.setting-page {
  min-height: 100vh;
  background: #0f172a;
  padding: 32rpx;
}
.section {
  background: rgba(30,41,59,0.5);
  border: 1rpx solid rgba(148,163,184,0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 16rpx;
}
.item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}
.item:last-child { border: none; }
.item-label { font-size: 28rpx; color: #94a3b8; }
.item-value { font-size: 28rpx; color: #f1f5f9; }
.footer {
  text-align: center;
  padding: 48rpx 0;
}
.footer-text {
  font-size: 22rpx;
  color: #475569;
}
