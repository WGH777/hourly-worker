/* 工时记录列表 */
.record-list {
  padding: 20rpx 32rpx;
  min-height: 400rpx;
}

/* 统计栏 */
.period-summary {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 24rpx 16rpx;
  margin-bottom: 24rpx;
  background: rgba(99,102,241,0.08);
  border: 1rpx solid rgba(99,102,241,0.15);
  border-radius: 16rpx;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #f1f5f9;
}
.stat-label {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 4rpx;
}
.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.1);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}
.empty-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 30rpx; color: #94a3b8; font-weight: 600; }
.empty-hint { font-size: 24rpx; color: #475569; margin-top: 8rpx; }

/* 记录卡片 */
.record-card {
  background: rgba(30,41,59,0.5);
  border: 1rpx solid rgba(148,163,184,0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.card-date {
  font-size: 26rpx;
  color: #94a3b8;
  font-weight: 500;
}
.card-delete {
  font-size: 22rpx;
  color: #ef4444;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(239,68,68,0.08);
}

.card-body {
  display: flex;
  gap: 40rpx;
}
.card-stat {
  display: flex;
  flex-direction: column;
}
.card-hours {
  font-size: 40rpx;
  font-weight: 800;
  color: #f1f5f9;
}
.card-income {
  font-size: 40rpx;
  font-weight: 800;
  color: #10b981;
}
.card-rate {
  font-size: 28rpx;
  color: #94a3b8;
  font-weight: 600;
}
.card-label {
  font-size: 20rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.card-footer {
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255,255,255,0.04);
}
.card-note {
  font-size: 24rpx;
  color: #64748b;
}
.card-actions {
  margin-top: 12rpx;
  text-align: right;
}
.edit-btn {
  font-size: 24rpx;
  color: #6366f1;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(99,102,241,0.08);
}
