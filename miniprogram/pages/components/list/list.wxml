<!-- 工时记录列表组件 -->
<view class="record-list">
  <!-- 日期区间统计栏 -->
  <view class="period-summary" wx:if="{{billResult.length}}">
    <view class="stat-item">
      <text class="stat-num">{{totalHours}}h</text>
      <text class="stat-label">总工时</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">¥{{totalIncome}}</text>
      <text class="stat-label">总收入</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{billResult.length}}天</text>
      <text class="stat-label">记录</text>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="empty-state" wx:if="{{!billResult || billResult.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无工时记录</text>
    <text class="empty-hint">点击中间 + 号添加吧</text>
  </view>

  <view wx:else class="list">
    <view class="record-card" wx:for="{{billResult}}" wx:key="_id">
      <!-- 日期 -->
      <view class="card-header">
        <text class="card-date">📅 {{item.noteDate}}</text>
        <text class="card-delete" bindtap="deleteRecord" data-id="{{item._id}}">删除</text>
      </view>
      <!-- 内容 -->
      <view class="card-body">
        <view class="card-stat">
          <text class="card-hours">{{item.hours}}h</text>
          <text class="card-label">工时</text>
        </view>
        <view class="card-stat">
          <text class="card-income">¥{{item.income}}</text>
          <text class="card-label">收入</text>
        </view>
        <view class="card-stat" wx:if="{{item.hourlyRate > 0}}">
          <text class="card-rate">¥{{item.hourlyRate}}/h</text>
          <text class="card-label">时薪</text>
        </view>
      </view>
      <!-- 备注 -->
      <view class="card-footer" wx:if="{{item.description}}">
        <text class="card-note">{{item.description}}</text>
      </view>
      <!-- 编辑入口 -->
      <view class="card-actions" wx:if="{{item.description || true}}">
        <text class="edit-btn" bindtap="editRecord" data-item="{{item}}">✏️ 编辑</text>
      </view>
    </view>
  </view>
</view>
