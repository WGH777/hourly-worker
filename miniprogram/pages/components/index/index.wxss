/* 工时记录录入组件 */
.container {
  padding: 20rpx 32rpx;
}

/* 日期选择器 */
.date-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  margin-bottom: 28rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 16rpx;
}
.date-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #f1f5f9;
}
.date-arrow {
  margin-left: 12rpx;
  font-size: 32rpx;
  color: #64748b;
}

/* 输入区 */
.input-section {
  margin-bottom: 24rpx;
}
.input-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.input-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #94a3b8;
}
.input-wrapper {
  flex: 1;
  display: flex;
  align-items: baseline;
}
.hours-input, .rate-input {
  flex: 1;
  font-size: 48rpx;
  font-weight: 700;
  color: #f1f5f9;
  text-align: right;
  padding: 8rpx 0;
}
.unit {
  margin-left: 12rpx;
  font-size: 26rpx;
  color: #64748b;
}
.note-row {
  border: none;
}
.note-input {
  flex: 1;
  font-size: 28rpx;
  color: #f1f5f9;
  text-align: right;
  padding: 8rpx 0;
}

/* 收入预览 */
.income-preview {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  margin: 20rpx 0;
  background: linear-gradient(135deg, rgba(16,185,129,0.12), rgba(16,185,129,0.04));
  border-radius: 16rpx;
  border: 1rpx solid rgba(16,185,129,0.2);
}
.income-label {
  font-size: 28rpx;
  color: #6ee7b7;
}
.income-value {
  font-size: 44rpx;
  font-weight: 800;
  color: #10b981;
}

/* 快捷时薪 */
.quick-rate {
  margin-bottom: 24rpx;
}
.hint-text {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 12rpx;
  display: block;
}
.rate-presets {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}
.preset {
  padding: 12rpx 32rpx;
  background: rgba(99,102,241,0.1);
  border: 1rpx solid rgba(99,102,241,0.25);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #a5b4fc;
  font-weight: 600;
}

/* 保存按钮 */
.submit-btn {
  width: 100%;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  border-radius: 16rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-top: 16rpx;
}
.submit-btn.loading {
  opacity: 0.6;
}
