<!-- 主页面：三 Tab 布局 -->
<view class="page">
  <!-- 自定义导航栏 -->
  <view class="nav" style="padding-top:{{sysInfo.statusBarHeight + 10}}px;">
    <view class="nav-content">
      <text class="nav-title">工时记账</text>
    </view>
  </view>

  <view class="main-content" style="height:{{sysInfo.screenHeight - sysInfo.statusBarHeight - 56 - 100}}px;">
    <!-- 中间页：工时录入 -->
    <view class="tab-panel index-panel" hidden="{{activeTab !== 'index'}}">
      <index id="index" isEdit="{{isEdit}}" bind:reFetchBillList="onReFetchBillList" bind:hideTab="onHideTab" />
    </view>

    <!-- 左页：日历 + 记录列表 -->
    <view class="tab-panel list-panel" hidden="{{activeTab !== 'list'}}">
      <!-- 日历组件 -->
      <view class="cal-calendar">
        <calendar
          id="calendar"
          mode="range"
          showToday="{{true}}"
          bind:onRangePick="onRangePick"
          bind:onControl="onControl"
          bind:onPickDateChange="onPickDateChange"
        />
      </view>
      <!-- 月度统计条 -->
      <view class="month-summary" wx:if="{{monthSummary.totalHours !== undefined}}">
        <text class="ms-item">⏱ {{monthSummary.totalHours}}h</text>
        <text class="ms-item">💰 ¥{{monthSummary.totalIncome}}</text>
        <text class="ms-item">📅 {{monthSummary.workDays}}天</text>
      </view>
      <!-- 记录列表 -->
      <list
        id="list"
        bind:reFetchBillList="onReFetchBillList"
        bind:switchTab="onSwitchTab"
        bind:editBill="onEditBill"
        bind:hideTab="onHideTab"
      />
    </view>

    <!-- 右页：月度统计图表 -->
    <view class="tab-panel chart-panel" hidden="{{activeTab !== 'chart'}}">
      <view class="chart-header">
        <text class="chart-month" bindtap="pickChartMonth">{{chartMonth || '本月'}} ▾</text>
      </view>
      <!-- 月度总览卡片 -->
      <view class="overview-cards" wx:if="{{chartData.summary}}">
        <view class="overview-card">
          <text class="oc-num">{{chartData.summary.totalHours}}h</text>
          <text class="oc-label">总工时</text>
        </view>
        <view class="overview-card green">
          <text class="oc-num">¥{{chartData.summary.totalIncome}}</text>
          <text class="oc-label">总收入</text>
        </view>
        <view class="overview-card purple">
          <text class="oc-num">{{chartData.summary.workDays}}天</text>
          <text class="oc-label">工作天数</text>
        </view>
      </view>
      <!-- 每日柱状图文字版（小程序原生列表替代 Canvas） -->
      <view class="daily-chart" wx:if="{{chartData.daily}}">
        <view class="chart-bar-row" wx:for="{{chartData.daily}}" wx:key="date">
          <text class="bar-date">{{item.date.split('-')[2]}}日</text>
          <view class="bar-track">
            <view class="bar-fill hours-bar" style="width:{{item.hours > 0 ? (item.hours / maxHours * 100) : 0}}%">
              <text wx:if="{{item.hours > 0}}" class="bar-text">{{item.hours}}h</text>
            </view>
          </view>
          <text class="bar-income" wx:if="{{item.income > 0}}">¥{{item.income}}</text>
        </view>
      </view>
      <!-- 空状态 -->
      <view class="chart-empty" wx:if="{{!chartData.summary}}">
        <text class="empty-icon">📊</text>
        <text class="empty-text">暂无统计数据</text>
      </view>
    </view>
  </view>

  <!-- 底部三 Tab 导航 -->
  <view class="tabbar" hidden="{{!showTabbar}}" style="bottom:{{0}}px;">
    <view class="tab-item {{activeTab === 'list' ? 'active' : ''}}" bindtap="goTo" data-active="list">
      <image class="tab-icon" src="/images/calendar-dark.png" mode="aspectFit" />
      <text class="tab-text">记录</text>
    </view>
    <view class="tab-center" bindtap="goTo" data-active="index">
      <view class="center-btn">
        <text class="center-icon">+</text>
      </view>
    </view>
    <view class="tab-item {{activeTab === 'chart' ? 'active' : ''}}" bindtap="goTo" data-active="chart">
      <image class="tab-icon" src="/images/图表.png" mode="aspectFit" />
      <text class="tab-text">统计</text>
    </view>
  </view>
</view>
