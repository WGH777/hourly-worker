/* 主页面样式 */
.page {
  min-height: 100vh;
  background: #0f172a;
  color: #f1f5f9;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

/* 导航栏 */
.nav {
  background: rgba(15,23,42,0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #f1f5f9;
}

/* 主内容区 */
.main-content {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}
.tab-panel {
  min-height: 100%;
}

/* 月度统计条 */
.month-summary {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  padding: 16rpx 32rpx;
  background: rgba(99,102,241,0.06);
  border-top: 1rpx solid rgba(99,102,241,0.1);
  border-bottom: 1rpx solid rgba(99,102,241,0.1);
}
.ms-item {
  font-size: 26rpx;
  color: #a5b4fc;
  font-weight: 600;
}

/* 底部导航栏 */
.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 12rpx 0 28rpx;
  background: rgba(15,23,42,0.95);
  backdrop-filter: blur(12px);
  border-top: 1rpx solid rgba(255,255,255,0.06);
  z-index: 100;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 0;
}
.tab-icon {
  width: 44rpx;
  height: 44rpx;
}
.tab-text {
  font-size: 20rpx;
  color: #64748b;
  margin-top: 4rpx;
}
.tab-item.active .tab-text {
  color: #6366f1;
}

/* 中间 + 按钮 */
.tab-center {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}
.center-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(99,102,241,0.4);
  margin-bottom: 16rpx;
}
.center-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
}

/* ============ 统计页面 ============ */
.chart-panel {
  padding: 24rpx 32rpx;
}
.chart-header {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}
.chart-month {
  font-size: 30rpx;
  font-weight: 600;
  color: #94a3b8;
  padding: 8rpx 32rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 12rpx;
}

/* 概览卡片 */
.overview-cards {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}
.overview-card {
  flex: 1;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(30,41,59,0.6);
  border: 1rpx solid rgba(148,163,184,0.08);
  text-align: center;
}
.overview-card.green { border-color: rgba(16,185,129,0.2); background: rgba(16,185,129,0.06); }
.overview-card.purple { border-color: rgba(99,102,241,0.2); background: rgba(99,102,241,0.06); }
.oc-num {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #f1f5f9;
}
.overview-card.green .oc-num { color: #10b981; }
.overview-card.purple .oc-num { color: #a5b4fc; }
.oc-label {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 6rpx;
}

/* 每日柱状图 */
.daily-chart {
  max-height: 600rpx;
  overflow-y: auto;
}
.chart-bar-row {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  gap: 12rpx;
}
.bar-date {
  width: 64rpx;
  font-size: 22rpx;
  color: #64748b;
  text-align: right;
}
.bar-track {
  flex: 1;
  height: 28rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 6rpx;
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  padding-left: 8rpx;
  min-width: 32rpx;
  transition: width 0.3s;
  background: linear-gradient(90deg, #6366f1, #8b5cf6);
}
.bar-text {
  font-size: 18rpx;
  color: #fff;
  font-weight: 600;
  white-space: nowrap;
}
.bar-income {
  width: 80rpx;
  font-size: 20rpx;
  color: #10b981;
  text-align: right;
}

.chart-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.chart-empty .empty-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.chart-empty .empty-text { font-size: 28rpx; color: #64748b; }
